# Copy to .env (local) or set these in your host's environment settings.
# Used by the contact + review form handlers to email submissions.

# --- SMTP (required for forms to send email) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-account@gmail.com
SMTP_PASS=your-app-password

# --- Addresses ---
# From address shown on outgoing mail (defaults to SMTP_USER if blank):
MAIL_FROM=
# Owner inbox that receives quote requests AND reviews for approval:
MAIL_TO=owner@clevelandsmarthomesolutions.com

# --- One-click review approval ---
# Secret used to sign approval links so they can't be forged. Falls back to
# SMTP_PASS if unset, but a dedicated value is recommended in production:
REVIEW_SECRET=a-long-random-string
# Canonical site origin used to build approval links in emails. Falls back to
# the request host if unset (set it so links point at production, not previews):
SITE_URL=https://www.clevelandsmarthomesolutions.com
# Durable storage for published reviews. Enable Blob in the Vercel project
# (Storage -> Blob) and Vercel injects this automatically — no need to set it
# by hand in production. Only needed locally to test publishing:
BLOB_READ_WRITE_TOKEN=
