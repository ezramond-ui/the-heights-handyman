# Copy to .env (local) or set these in your host's environment settings.
# Used by the contact form handler to email submissions.

# --- SMTP (required for the form to send email) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-account@gmail.com
SMTP_PASS=your-app-password

# --- Addresses ---
# From address shown on outgoing mail (defaults to SMTP_USER if blank):
MAIL_FROM=
# Inbox that receives contact-form / free-estimate requests:
MAIL_TO=ezra@theheightshandyman.com
